@model ProductUpdateVM

<div class="row">
    <div class="col-md-6 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">

                <h4 class="card-title">Update Product</h4>

                <form class="forms-sample"
                      method="post"
                      enctype="multipart/form-data">

                    <div class="form-group">
                        <label>Name</label>

                        <input asp-for="Name"
                               class="form-control"
                               placeholder="Name" />

                        <span asp-validation-for="Name"
                              class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label>Price</label>

                        <input asp-for="Price"
                               class="form-control"
                               placeholder="Price" />

                        <span asp-validation-for="Price"
                              class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label>SKU</label>

                        <input asp-for="SKU"
                               class="form-control"
                               placeholder="SKU" />

                        <span asp-validation-for="SKU"
                              class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label>Tags</label>

                        <select asp-for="TagIDs"
                                class="form-control"
                                asp-items="new SelectList(Model.Tags, nameof(Tag.Id), nameof(Tag.Name))"
                                multiple>
                        </select>

                        <span asp-validation-for="TagIDs"
                              class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label>Category</label>

                        <select asp-for="CategoryId"
                                class="form-control"
                                asp-items="new SelectList(Model.Categories, nameof(Category.Id), nameof(Category.Name))">
                        </select>

                        <span asp-validation-for="CategoryId"
                              class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label>Description</label>

                        <textarea asp-for="Description"
                                  class="form-control"
                                  placeholder="Description">
                        </textarea>

                        <span asp-validation-for="Description"
                              class="text-danger"></span>
                    </div>

                    <button type="submit"
                            class="btn btn-primary me-2">
                        Submit
                    </button>

                    <a asp-action="Index"
                       class="btn btn-light">
                        Cancel
                    </a>

                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}