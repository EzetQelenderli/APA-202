@using _27_FrontToBackSqlConnection.Areas.AdminPanel.ViewModels
@model ProductUpdateVM

@{
    ProductImage mainImage = Model.ProductImages.FirstOrDefault(pi => pi.IsPrimary == true);
    ProductImage hoverImage = Model.ProductImages.FirstOrDefault(pi => pi.IsPrimary == false);
    List<ProductImage> addImage = Model.ProductImages.Where(pi => pi.IsPrimary == null).ToList();
}



<div class="row">
    <div class="col-md-6 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">

                <h4 class="card-title">Update Product</h4>

                <form class="forms-sample"
                      method="post"
                      enctype="multipart/form-data">

                    <div class="form-group">

                        <img style="width:100px"
                             src="~/assets/images/website-images/@mainImage.Image" />
                        <br />

                        <label>Main Image</label>

                        <input asp-for="MainPhoto"
                               class="form-control" />

                        <span asp-validation-for="MainPhoto"
                              class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <img style="width:100px"
                             src="~/assets/images/website-images/@hoverImage.Image" />
                        <br />

                        <label>Secondary Image</label>

                        <input asp-for="HoverPhoto"
                               class="form-control" />

                        <span asp-validation-for="HoverPhoto"
                              class="text-danger"></span>
                    </div>

                    <div class="form-group d-flex">
                        @foreach (var addImage in addImage)
                        {
                            <div style="position:relative">
                                <img style="width:100px"
                                     src="~/assets/images/website-images/@addImage" />
                                <i class=" custom-btn mdi mdi-close-circle" style="cursor:pointer;position:absolute;top:5px;right:5px"></i>
                                <input asp-for="ImageIds" type="hidden" value="@addImage.Id" />
                            </div>
                        }

                    </div>
                    <div class="form-group">
                        <div>
                        </div>
                        <label>Additional Images</label>

                        <input asp-for="AdditionalPhotos"
                               class="form-control" />

                        <span asp-validation-for="ImageIds"
                              class="text-danger"></span>
                    </div>

                    <div class="form-group">

                        <label>Name</label>

                        <input asp-for="Name"
                               class="form-control"
                               placeholder="Name" />

                        <span asp-validation-for="Name"
                              class="text-danger"></span>
                    </div>

                    <div class="form-group">

                        <label>Price</label>

                        <input asp-for="Price"
                               class="form-control"
                               placeholder="Price" />

                        <span asp-validation-for="Price"
                              class="text-danger"></span>
                    </div>

                    <div class="form-group">

                        <label>SKU</label>

                        <input asp-for="SKU"
                               class="form-control"
                               placeholder="SKU" />

                        <span asp-validation-for="SKU"
                              class="text-danger"></span>
                    </div>

                    <div class="form-group">

                        <label>Tags</label>

                        <select asp-for="TagIds"
                                class="form-control"
                                asp-items="new SelectList(Model.Tags, nameof(Tag.Id), nameof(Tag.Name))"
                                multiple>
                        </select>

                        <span asp-validation-for="TagIds"
                              class="text-danger"></span>
                    </div>

                    <div class="form-group">

                        <label>Category</label>

                        <select asp-for="CategoryId"
                                class="form-control"
                                asp-items="new SelectList(Model.Categories, nameof(Category.Id), nameof(Category.Name))">
                        </select>

                        <span asp-validation-for="CategoryId"
                              class="text-danger"></span>
                    </div>

                    <div class="form-group">

                        <label>Description</label>

                        <textarea asp-for="Description"
                                  class="form-control"
                                  placeholder="Description">
                        </textarea>

                        <span asp-validation-for="Description"
                              class="text-danger"></span>
                    </div>

                    <button type="submit"
                            class="btn btn-primary me-2">
                        Submit
                    </button>

                    <a asp-action="Index"
                       class="btn btn-light">
                        Cancel
                    </a>

                </form>

            </div>
        </div>
    </div>
</div>

@section DeleteImages{
    <script>
        var btns=document.querySelectorAll(".custom-btn");
        for (let i=0;i<btns.length;i++)
        {
            btns[i].addEventListener("click",()={
                btns[i].parentElement.remove();
            })
        }
    </script>
}