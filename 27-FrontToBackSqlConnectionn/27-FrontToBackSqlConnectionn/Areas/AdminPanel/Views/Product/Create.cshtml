@model ProductCreateVM

<div class="row">
    <div class="col-md-6 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Create Product</h4>

                <form class="forms-sample" method="post" enctype="multipart/form-data">

                    <div class="form-group">
                        <label asp-for="Name"></label>
                        <input asp-for="Name" class="form-control" placeholder="Name">
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Price"></label>
                        <input asp-for="Price" class="form-control" placeholder="Price">
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="SKU"></label>
                        <input asp-for="SKU" class="form-control" placeholder="SKU">
                        <span asp-validation-for="SKU" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label for Name="Tag"></label>
                        <input asp-for="TagIDs" class="form-control" asp-items="new SelectList (@Model.Tags))">
                        <span asp-validation-for="TagIds" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label for Name="Category"></label>
                        <input asp-for="CategoryId" class="form-control" asp-items="new SelectList @Model.CategoryId">
                        <span asp-validation-for="CategoryId" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Description"></label>
                        <input asp-for="Description" class="form-control" placeholder="Description">
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="CategoryId"></label>

                        <select asp-for="CategoryId" class="form-control">
                            <option selected disabled>Choose Category</option>
                            @foreach (Category category in Model.Categories)
                            {
                                <option value="@category.Id">
                                    @category.Name
                                </option>
                            }
                        </select>

                    </div>

                    

                    <button type="submit" class="btn btn-primary me-2">
                        Submit
                    </button>

                    <a asp-action="Index" class="btn btn-light">
                        Cancel
                    </a>

                </form>
            </div>
        </div>
    </div>
</div>