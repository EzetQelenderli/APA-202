@model SliderDetailVM
@using _27_FrontToBackSqlConnectionn.Models



<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">

                <h4 class="card-title">Slider Detail</h4>

                <div class="table-responsive">

                    <table class="table table-striped">

                        <thead>
                            <tr>
                                <th>Image</th>
                                <th>Title</th>
                                <th>Subtitle</th>
                                <th>Order</th>
                                <th>Description</th>
                            </tr>
                        </thead>

                        <tbody>

                            
                                <tr>

                                    

                                    <td>
                                        <img style="width:70px; height:70px;"
                                             src="~/assets/images/website-images/@Model.Image" />
                                    </td>

                                    <td>
                                    <p>@Model.Title</p>
                                    </td>

                                    <td>
                                    <p>@Model.Subtitle</p>
                                    </td>

                                    <td>
                                    <p>@Model.Order</p>
                                    </td>
                                    <td>
                                    <p>@Model.Description</p>
                                    </td>

                                    <td>


                                    </td>

                                </tr>
                            }

                        </tbody>
                        <a asp-action="index" class="btn btn-light">Cancel</a>

                    </table>


                </div>
            </div>
        </div>
    </div>
</div>